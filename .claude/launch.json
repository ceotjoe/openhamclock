{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "OpenHamClock (Vite dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "OpenHamClock (Express server)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 3000
    },
    {
      "name": "OpenHamClock (Express dev API)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "env": { "PORT": "3001" },
      "port": 3001
    },
    {
      "name": "DX Spider Proxy",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dxspider-proxy/server.js"],
      "port": 3001
    },
    {
      "name": "ITURHFProp Service",
      "runtimeExecutable": "node",
      "runtimeArgs": ["iturhfprop-service/server.js"],
      "port": 3000
    },
    {
      "name": "Rig Bridge",
      "runtimeExecutable": "node",
      "runtimeArgs": ["rig-bridge/rig-bridge.js"],
      "port": 5555
    },
    {
      "name": "Rig Control (legacy daemon)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["rig-control/rig-daemon.js"],
      "port": 5555
    }
  ],
  "autoVerify": false
}
